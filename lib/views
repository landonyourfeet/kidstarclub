async function countView(pool, videoId) {
  const { rows: [v] } = await pool.query(
    `UPDATE videos SET views = views + 1 WHERE id=$1 AND status='live' RETURNING views`,
    [videoId]);
  return v?.views ?? 0;
}

module.exports = { countView };
